GEMINI_API_KEY=YOUR_API_KEY
# gemini-2.5-flash: confirmed working with AQ. key format (June 2026)
# gemini-1.5-flash: returns 404 NOT FOUND — model removed from v1beta API
# gemini-2.0-flash: may return 429 quota exhausted on free tier
GEMINI_MODEL_ID=gemini-2.5-flash
GITHUB_TOKEN=YOUR_TOKEN
GITHUB_CLIENT_ID=YOUR_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET
GITHUB_REDIRECT_URI=http://localhost:4200/auth/callback
SESSION_SECRET_KEY=change-me-to-a-random-secret
SESSION_TTL_HOURS=8

# ---------------------------------------------------------------------------
# Microsoft Azure AI Foundry IQ — Camada de conhecimento arquitetural (Recall)
# Requisito obrigatório do hackathon: "Foundry IQ Layer"
# Obtenha os valores no portal Azure AI Foundry > seu projeto > Configurações
# ---------------------------------------------------------------------------
AZURE_AI_FOUNDRY_ENDPOINT=https://YOUR_PROJECT.cognitiveservices.azure.com
AZURE_AI_FOUNDRY_KEY=YOUR_AZURE_AI_SEARCH_KEY
AZURE_AI_FOUNDRY_INDEX=recall-architecture-guidelines
